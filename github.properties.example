# Скопируй в github.properties (файл в .gitignore) или задай переменные окружения GPR_USER / GPR_TOKEN.
# Токен: GitHub → Settings → Developer settings → PAT с правами read:packages (потребители) и write:packages (публикация).

gpr.user=YOUR_GITHUB_USERNAME
gpr.key=ghp_your_personal_access_token

# --- Потребитель приложения ---
